{
  "name": "servis-platform",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev:api": "pnpm --filter @servis/api start:dev",
    "dev:web": "pnpm --filter @servis/web dev",
    "build": "pnpm -r build",
    "migration:run": "pnpm --filter @servis/db migration:run",
    "migration:generate": "pnpm --filter @servis/db migration:generate"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "argon2", "sharp"]
  }
}
